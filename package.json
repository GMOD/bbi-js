{
  "name": "@gmod/bbi",
  "version": "9.0.4",
  "description": "Parser for BigWig/BigBed files",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/bbi-js.git"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": "./esm/index.js",
    "require": "./dist/index.js"
  },
  "author": {
    "name": "Colin Diesh",
    "email": "colin.diesh@gmail.com",
    "url": "https://github.com/cmdcolin"
  },
  "files": [
    "dist",
    "esm",
    "src"
  ],
  "scripts": {
    "test": "vitest",
    "benchonly": "vitest bench",
    "bench": "./scripts/build-both-branches.sh \"$BRANCH1\" \"$BRANCH2\" && vitest bench",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "clean": "rimraf dist esm",
    "prebuild": "pnpm clean",
    "build:wasm": "pnpm --filter inflate-wasm-build build",
    "build:esm": "tsc --outDir esm",
    "build:es5": "tsc --module commonjs --moduleResolution bundler --outDir dist",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "build": "pnpm build:wasm && pnpm build:esm && pnpm build:es5",
    "preversion": "pnpm lint && pnpm test --run && pnpm build",
    "version": "standard-changelog && git add CHANGELOG.md",
    "postversion": "git push --follow-tags"
  },
  "keywords": [
    "bionode",
    "biojs",
    "bigwig",
    "bigbed",
    "ucsc",
    "genomics"
  ],
  "dependencies": {
    "@gmod/abortable-promise-cache": "^3.0.4",
    "@jbrowse/quick-lru": "^7.3.5",
    "generic-filehandle2": "^2.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@gmod/bed": "^2.1.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "standard-changelog": "^7.0.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
