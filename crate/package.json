{
  "name": "inflate-wasm-build",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:wasm": "cargo build --release --target wasm32-unknown-unknown && wasm-bindgen --target bundler --out-dir ../src/wasm target/wasm32-unknown-unknown/release/inflate_wasm.wasm",
    "build:bundle": "webpack --config webpack.config.js",
    "build": "pnpm build:wasm && pnpm build:bundle"
  },
  "devDependencies": {
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
